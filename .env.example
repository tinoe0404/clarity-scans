# Database (Neon Postgres - free tier)
# Get from: https://neon.tech → New Project → Connection string
DATABASE_URL=

# Vercel Blob Storage (free tier - 1GB)
# Get from: Vercel Dashboard → Storage → Create Blob Store → .env.local
BLOB_READ_WRITE_TOKEN=

# NextAuth (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Admin credentials (radiographer dashboard)
# ADMIN_PASSWORD_HASH: generate with bcrypt, rounds=12
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# App config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=en
