# Database (Neon Postgres - free tier)
# Get from: https://neon.tech → New Project → Connection string
DATABASE_URL=postgresql://neondb_owner:npg_h4q5axbLnfsR@ep-gentle-mode-am9lyouq-pooler.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# --- CLOUDFLARE R2 STORAGE (free tier - 10GB) ---
# Get from: https://dash.cloudflare.com → R2 → Overview → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=clarity-scans
# Public URL for the bucket (enable public access in R2 dashboard or use custom domain)
R2_PUBLIC_URL=

# --- AUTHENTICATION ---

# NextAuth secret — generate with: openssl rand -base64 32
# Must be at least 32 characters. Required in production.
NEXTAUTH_SECRET=iUgN9i+Bc0lJrIxWVbup9MxoHY88oZP29SygU41VAlY=

# NextAuth URL — must match your deployment URL exactly
# In development: http://localhost:3000
# In production: https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Admin username for radiographer dashboard access
# Can be any string — recommend using the hospital name or department
ADMIN_USERNAME=admin

# Admin password hash — generate with: npx tsx src/lib/hashPassword.ts yourpassword
# Never store the plaintext password anywhere
# This uses bcrypt with 12 rounds
ADMIN_PASSWORD_HASH=$2b$12$DgXIdVRyGXhl.muhtagnBe7sGjibLDDI27343EYhso4QLqh66CCTu

# --- CACHE MANAGEMENT ---

# Next.js Cache Revalidation secret — generate with: openssl rand -base64 32
# Used by the Admin CMS to instantly bust the 1hr public Video Segment caches.
REVALIDATION_SECRET=VO4LJgqi/itsmpmDo0e/AjdLQqtfng/J0PxgHWnbWBQ=

# --- APP CONFIG ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=en
