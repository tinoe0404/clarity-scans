# Database (Neon Postgres - free tier)
# Get from: https://neon.tech → New Project → Connection string
DATABASE_URL=

# Vercel Blob Storage (free tier - 1GB)
# Get from: Vercel Dashboard → Storage → Create Blob Store → .env.local
BLOB_READ_WRITE_TOKEN=

# --- AUTHENTICATION ---

# NextAuth secret — generate with: openssl rand -base64 32
# Must be at least 32 characters. Required in production.
NEXTAUTH_SECRET=

# NextAuth URL — must match your deployment URL exactly
# In development: http://localhost:3000
# In production: https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Admin username for radiographer dashboard access
# Can be any string — recommend using the hospital name or department
ADMIN_USERNAME=admin

# Admin password hash — generate with: npx tsx src/lib/hashPassword.ts yourpassword
# Never store the plaintext password anywhere
# This uses bcrypt with 12 rounds
ADMIN_PASSWORD_HASH=

# --- APP CONFIG ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=en
